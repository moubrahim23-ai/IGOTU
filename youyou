        .Cells(targetRow, 7).Value = cmbType.Value
        .Cells(targetRow, 8).Value = cmbDecisionSolva.Value
        .Cells(targetRow, 9).Value = comment.Value
        .Cells(targetRow, 10).Value = .Cells(targetRow, 4).Value - .Cells(targetRow, 3).Value
    End With
End Sub

' ------------------------------------------------------------------
' Add new record (cmb_Ajouter_Click)
' ------------------------------------------------------------------
Private Sub cmb_Ajouter_Click()
    Dim ws As Worksheet
    Set ws = GetTempSheet()
    Dim wsTemp As Worksheet
    Set wsTemp = GetTempSheet()
    
    Dim lastRow As Long, i As Long
    lastRow = wsTemp.Cells(wsTemp.Rows.Count, 1).End(xlUp).Row
    
    For i = 2 To lastRow
        ' Si la ligne a une heure de début (colonne C) mais pas d'heure de fin (colonne D)
        If wsTemp.Cells(i, 3).Value <> "" And wsTemp.Cells(i, 4).Value = "" Then
            MsgBox "Veuillez compléter la ligne précédente (en attente) avant d'ajouter un nouveau dossier.", vbExclamation
            Exit Sub
        End If
    Next i
    
    Dim refValue As String
    refValue = Trim(txtDossier.Value)
    If cmbTraitement.Value = "" Then
            MsgBox "Veuillez choisir un type de traitement"
            Exit Sub
    End If
    If cmbTraitement.Value = "SOLVA" Then
        If refValue = "" Then
            MsgBox "Veuillez saisir une référence dossier.", vbExclamation
            Exit Sub
        ElseIf Solvabilité.Value = "" Then
            MsgBox "Veuillez remplir la Solvabilité.", vbExclamation
            Exit Sub
        End If
    Else
        If refValue = "" Then
            MsgBox "Veuillez saisir une référence dossier.", vbExclamation
            Exit Sub
        ElseIf cmbProduits.Value = "" Then
            MsgBox "Veuillez choisir un type de Produit.", vbExclamation
            Exit Sub
        ElseIf cmbCredit.Value = "" Then
            MsgBox "Veuillez choisir un type de Crédit.", vbExclamation
            Exit Sub
        End If
    End If
    
    Dim canal As String
    
    If optBO.Value = True Then
        canal = "Back-Office"
    ElseIf optFO.Value = True Then
        canal = "Front-Office"
    Else
        MsgBox "Veuillez sélectionner un CANAL : Back-Office ou Front-Office."
        Exit Sub
    End If
 

    
    lastRow = ws.Cells(ws.Rows.Count, 1).End(xlUp).Row
    
    ' Determine column where reference is stored
    Dim refCol As Long
    If cmbTraitement.Value = "SOLVA" Then
        refCol = 6   ' column F
    Else
        refCol = 7   ' column G
    End If
    
    ' Check for duplicate reference
    For i = 2 To lastRow
        If ws.Cells(i, refCol).Value = refValue Then
            MsgBox "La référence dossier '" & refValue & "' existe déjà !", vbCritical
            Exit Sub
        End If
    Next i
    
    Dim newRow As Long
    newRow = lastRow + 1
    
    With ws
        .Cells(newRow, 1).Value = Environ("USERNAME")
        .Cells(newRow, 2).Value = cmbTraitement.Value
        .Cells(newRow, 3).Value = Now
        If cmbTraitement.Value = "SOLVA" Then
            .Cells(newRow, 5).Value = Solvabilité.Value
            .Cells(newRow, 6).Value = txtDossier.Value
            .Cells(newRow, 11).Value = canal
        Else
            .Cells(newRow, 5).Value = cmbCredit.Value
            .Cells(newRow, 6).Value = cmbProduits.Value
            .Cells(newRow, 7).Value = txtDossier.Value
            .Cells(newRow, 12).Value = canal
        End If
    End With
    
    ' Log to extraction sheet
    If cmbTraitement.Value = "SOLVA" Then
        Call logSolva_Etape1
    Else
        Call log_Etape1
    End If
    
    Call clearform
    Call RefreshListView
    MsgBox "Dossier ajouté avec succès !", vbInformation
End Sub

' ------------------------------------------------------------------
' Save modifications (cmb_Terminer_Click)
' ------------------------------------------------------------------
Private Sub cmb_Terminer_Click()
    Dim ws As Worksheet
    Set ws = GetTempSheet()
    
    If currentRow = 0 Then
        MsgBox "Veuillez d'abord rechercher et sélectionner une ligne à modifier.", vbExclamation
        Exit Sub
    End If
    
    If cmbTraitement.Value = "SOLVA" Then
        ' SOLVA case
        If cmbDecisionSolva.Value = "" Then
            MsgBox "Veuillez sélectionner une décision solvabilité."
            Exit Sub
        End If
        
        With ws
            .Cells(currentRow, 4).Value = Now
            .Cells(currentRow, 5).Value = Solvabilité.Value
            .Cells(currentRow, 7).Value = cmbType.Value
            .Cells(currentRow, 8).Value = cmbDecisionSolva.Value
            .Cells(currentRow, 9).Value = comment.Value
            .Cells(currentRow, 10).Value = .Cells(currentRow, 4).Value - .Cells(currentRow, 3).Value
        End With
        
        Call log_Etape2_Solva
    Else
        ' Normal case (OCAOCR / ETUDEINC)
        If cmbSignature.Value = "" Then
            MsgBox "Veuillez remplir l'activité."
            Exit Sub
        ElseIf cmbDecision.Value = "" Then
            MsgBox "Veuillez sélectionner le produit."
            Exit Sub
        End If
        
        With ws
            .Cells(currentRow, 4).Value = Now
            .Cells(currentRow, 8).Value = cmbSignature.Value
            .Cells(currentRow, 9).Value = cmbDecision.Value
            .Cells(currentRow, 10).Value = comment.Value
            .Cells(currentRow, 11).Value = .Cells(currentRow, 4).Value - .Cells(currentRow, 3).Value
        End With
        
        Call log_Etape2
    End If
    
    Call clearform
    Call RefreshListView
    MsgBox "Modifications enregistrées.", vbInformation
End Sub

